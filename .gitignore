# =======================================================================
# Unified GitIgnore for Internal Reporting System (Backend, Web, Mobile)
# =======================================================================

# ── System / OS Files ──
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp

# ── IDEs and Editors ──
.idea/
.vscode/
!.vscode/extensions.json
*.iml
*.ipr
*.iws
*.suo
*.sln

# ── Backend (Node.js) ──
backend/node_modules/
backend/.env
backend/npm-debug.log*

# ── Web Frontend (React + Vite) ──
web/node_modules/
web/dist/
web/dist-ssr/
web/.env
web/.env.local
web/.env.*.local
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*
web/pnpm-debug.log*

# ── Flutter Mobile App ──
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/.pub-cache/
mobile/.pub/
mobile/build/
mobile/coverage/
mobile/ios/Flutter/.last_build_id
mobile/android/app/debug/
mobile/android/app/profile/
mobile/android/app/release/
mobile/android/local.properties
mobile/android/.gradle/
mobile/app.*.symbols 
mobile/app.*.map.json

.md